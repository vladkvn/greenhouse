# Used by root docker-compose.yml (copy to .env)
API_KEY=dev-api-key-change-me
COMMANDER_API_KEY=dev-commander-key-change-me

# Optional: ESP8266 /command token (must match COMMAND_TOKEN in esp8266-web-bridge.ino if set)
COMMAND_TOKEN=

# Port on the device for HTTP (ESP8266 web server, usually 80)
DEVICE_HTTP_PORT=80
