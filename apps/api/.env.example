# PostgreSQL (local: use port 5433 if using root docker-compose.yml — host maps 5433→container 5432)
DATABASE_URL="postgresql://greenhouse:greenhouse@localhost:5433/greenhouse"

# Shared secret for device HTTP calls (Arduino sends X-API-Key)
API_KEY="change-me"

# Optional: HTTP port (default 3000)
# PORT=3000

# MQTT broker (same as Mosquitto). In Docker: mqtt://mosquitto:1883 — locally: mqtt://localhost:1883
MQTT_URL="mqtt://localhost:1883"
